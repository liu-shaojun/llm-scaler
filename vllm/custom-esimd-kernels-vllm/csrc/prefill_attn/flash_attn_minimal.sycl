// Task 1: Single-thread Flash Attention with Online Softmax
// Full algorithm, single WG = single thread, no parallelism.
// Purpose: verify online softmax correctness across arbitrary KV lengths.
//
// Computes: O = softmax(Q @ K^T / sqrt(256)) @ V
// Input:  Q [q_len, 256] fp16, K [kv_len, 256] fp16, V [kv_len, 256] fp16
// Output: O [q_len, 256] fp16
//
// Constraints: q_len <= 4 (fits in registers), kv_len = arbitrary (streamed via tiles)

#include <torch/extension.h>
#include <c10/xpu/XPUStream.h>
#include <sycl/sycl.hpp>
#include <sycl/ext/intel/esimd.hpp>
#include <sycl/ext/intel/experimental/esimd/memory.hpp>

using fp16 = sycl::half;
using namespace sycl::ext::intel::esimd;
namespace xesimd = sycl::ext::intel::experimental::esimd;

constexpr int HD = 256;
constexpr int KV_TILE = 32;
constexpr int Q_ROWS = 4;
constexpr float SCALE = 0.0625f;  // 1/sqrt(256) = 1/16

// Helper: load HD=256 fp16 vector (4 × 64-element loads)
template<int N_ROWS>
ESIMD_INLINE void load_rows(fp16* base, int stride, simd<fp16, N_ROWS * HD>& dst) {
#pragma unroll
    for (int r = 0; r < N_ROWS; r++) {
#pragma unroll
        for (int c = 0; c < HD; c += 64) {
            dst.template select<64, 1>(r * HD + c) =
                xesimd::lsc_block_load<fp16, 64,
                    xesimd::lsc_data_size::default_size,
                    xesimd::cache_hint::cached,
                    xesimd::cache_hint::cached>(base + r * stride + c);
        }
    }
}

// Helper: store HD=256 fp16 vector
template<int N_ROWS>
ESIMD_INLINE void store_rows(fp16* base, int stride, simd<fp16, N_ROWS * HD>& src) {
#pragma unroll
    for (int r = 0; r < N_ROWS; r++) {
#pragma unroll
        for (int c = 0; c < HD; c += 64) {
            xesimd::lsc_block_store<fp16, 64,
                xesimd::lsc_data_size::default_size,
                xesimd::cache_hint::write_back,
                xesimd::cache_hint::write_back>(
                base + r * stride + c,
                src.template select<64, 1>(r * HD + c));
        }
    }
}

ESIMD_INLINE void flash_attn_single_thread(
    uint8_t* Q_ptr,   // [q_len, 256] fp16
    uint8_t* K_ptr,   // [kv_len, 256] fp16
    uint8_t* V_ptr,   // [kv_len, 256] fp16
    uint8_t* O_ptr,   // [q_len, 256] fp16
    uint32_t q_len,
    uint32_t kv_len,
    sycl::nd_item<1>& ndi) {

    // State: online softmax accumulators (fp32)
    simd<float, Q_ROWS * HD> accum = 0.0f;    // weighted V accumulator
    simd<float, Q_ROWS> row_max;               // running max per Q row
    simd<float, Q_ROWS> row_sum = 0.0f;        // running exp sum per Q row
    row_max = -1e38f;

    // Load Q (up to Q_ROWS rows)
    simd<fp16, Q_ROWS * HD> Q_data = 0;
    uint32_t actual_q = (q_len < Q_ROWS) ? q_len : Q_ROWS;
#pragma unroll
    for (uint32_t r = 0; r < Q_ROWS; r++) {
        if (r < actual_q) {
#pragma unroll
            for (int c = 0; c < HD; c += 64) {
                Q_data.template select<64, 1>(r * HD + c) =
                    xesimd::lsc_block_load<fp16, 64,
                        xesimd::lsc_data_size::default_size,
                        xesimd::cache_hint::cached,
                        xesimd::cache_hint::cached>(
                        (fp16*)Q_ptr + r * HD + c);
            }
        }
    }

    // Outer loop: stream over KV in tiles of KV_TILE
    uint32_t kv_tiles = (kv_len + KV_TILE - 1) / KV_TILE;

    for (uint32_t tile = 0; tile < kv_tiles; tile++) {
        uint32_t kv_offset = tile * KV_TILE;
        uint32_t tile_len = KV_TILE;
        if (kv_offset + tile_len > kv_len) tile_len = kv_len - kv_offset;

        // Load K tile [tile_len, 256]
        // Compute QK^T scores [Q_ROWS, tile_len] in fp32
        simd<float, Q_ROWS * KV_TILE> scores = 0.0f;

#pragma unroll
        for (uint32_t kv = 0; kv < KV_TILE; kv++) {
            if (kv >= tile_len) break;

            // Load one K row
            simd<fp16, HD> K_row;
#pragma unroll
            for (int c = 0; c < HD; c += 64) {
                K_row.template select<64, 1>(c) =
                    xesimd::lsc_block_load<fp16, 64,
                        xesimd::lsc_data_size::default_size,
                        xesimd::cache_hint::cached,
                        xesimd::cache_hint::cached>(
                        (fp16*)K_ptr + (kv_offset + kv) * HD + c);
            }

            // Dot product Q[r] · K[kv] for each Q row
#pragma unroll
            for (uint32_t q = 0; q < Q_ROWS; q++) {
                if (q >= actual_q) break;
                float dot = 0.0f;
#pragma unroll
                for (int d = 0; d < HD; d += 16) {
                    simd<float, 16> q_f = Q_data.template select<16, 1>(q * HD + d);
                    simd<float, 16> k_f = K_row.template select<16, 1>(d);
                    dot += reduce<float>(q_f * k_f, std::plus<>());
                }
                scores[q * KV_TILE + kv] = dot * SCALE;
            }
        }

        // Online softmax update per Q row
#pragma unroll
        for (uint32_t q = 0; q < Q_ROWS; q++) {
            if (q >= actual_q) continue;

            // Find max in this tile's scores
            float tile_max = -1e38f;
#pragma unroll
            for (uint32_t kv = 0; kv < KV_TILE; kv++) {
                if (kv >= tile_len) break;
                float s = scores[q * KV_TILE + kv];
                if (s > tile_max) tile_max = s;
            }

            // New running max
            float old_max = row_max[q];
            float new_max = (tile_max > old_max) ? tile_max : old_max;

            // Rescale existing accumulator: accum *= exp(old_max - new_max)
            float rescale = __builtin_expf(old_max - new_max);
            row_sum[q] *= rescale;
#pragma unroll
            for (int d = 0; d < HD; d++) {
                accum[q * HD + d] *= rescale;
            }

            // Compute exp(score - new_max) and accumulate P @ V
            for (uint32_t kv = 0; kv < KV_TILE; kv++) {
                if (kv >= tile_len) break;
                float p = __builtin_expf(scores[q * KV_TILE + kv] - new_max);
                row_sum[q] += p;

                // Load V row and accumulate: accum[q] += p * V[kv]
                // (Reload V each time — single thread, not optimized)
#pragma unroll
                for (int c = 0; c < HD; c += 64) {
                    simd<fp16, 64> v_chunk =
                        xesimd::lsc_block_load<fp16, 64,
                            xesimd::lsc_data_size::default_size,
                            xesimd::cache_hint::cached,
                            xesimd::cache_hint::cached>(
                            (fp16*)V_ptr + (kv_offset + kv) * HD + c);
                    simd<float, 64> v_f32 = v_chunk;
#pragma unroll
                    for (int i = 0; i < 64; i++) {
                        accum[q * HD + c + i] += p * v_f32[i];
                    }
                }
            }

            row_max[q] = new_max;
        }
    }

    // Finalize: O = accum / row_sum, convert to fp16
    simd<fp16, Q_ROWS * HD> output;
#pragma unroll
    for (uint32_t q = 0; q < Q_ROWS; q++) {
        if (q >= actual_q) continue;
        float inv_sum = 1.0f / row_sum[q];
#pragma unroll
        for (int d = 0; d < HD; d++) {
            output[q * HD + d] = (fp16)(accum[q * HD + d] * inv_sum);
        }
    }

    // Store output
#pragma unroll
    for (uint32_t r = 0; r < Q_ROWS; r++) {
        if (r >= actual_q) continue;
#pragma unroll
        for (int c = 0; c < HD; c += 64) {
            xesimd::lsc_block_store<fp16, 64,
                xesimd::lsc_data_size::default_size,
                xesimd::cache_hint::write_back,
                xesimd::cache_hint::write_back>(
                (fp16*)O_ptr + r * HD + c,
                output.template select<64, 1>(r * HD + c));
        }
    }
}

// Torch entry point
at::Tensor flash_attn_minimal_forward(at::Tensor Q, at::Tensor K, at::Tensor V) {
    TORCH_CHECK(Q.device().is_xpu(), "Q must be on XPU");
    TORCH_CHECK(Q.dtype() == at::kHalf, "Q must be fp16");
    TORCH_CHECK(K.dtype() == at::kHalf && V.dtype() == at::kHalf, "K/V must be fp16");
    TORCH_CHECK(Q.dim() == 2 && Q.size(1) == 256, "Q must be [q_len, 256]");
    TORCH_CHECK(K.dim() == 2 && K.size(1) == 256, "K must be [kv_len, 256]");
    TORCH_CHECK(V.dim() == 2 && V.size(1) == 256, "V must be [kv_len, 256]");
    TORCH_CHECK(K.size(0) == V.size(0), "K and V must have same length");
    TORCH_CHECK(Q.size(0) <= 4, "q_len must be <= 4 for single-thread version");
    TORCH_CHECK(Q.is_contiguous() && K.is_contiguous() && V.is_contiguous(),
                "inputs must be contiguous");

    int q_len = Q.size(0);
    int kv_len = K.size(0);
    auto out = at::empty_like(Q);

    auto* q_ptr = reinterpret_cast<uint8_t*>(Q.data_ptr());
    auto* k_ptr = reinterpret_cast<uint8_t*>(K.data_ptr());
    auto* v_ptr = reinterpret_cast<uint8_t*>(V.data_ptr());
    auto* o_ptr = reinterpret_cast<uint8_t*>(out.data_ptr());

    sycl::queue& queue = c10::xpu::getCurrentXPUStream(Q.device().index()).queue();

    queue.submit([&](sycl::handler& cgh) {
        cgh.parallel_for<class flash_attn_minimal_kernel>(
            sycl::nd_range<1>(1, 1),
            [=](sycl::nd_item<1> ndi) SYCL_ESIMD_KERNEL {
                flash_attn_single_thread(q_ptr, k_ptr, v_ptr, o_ptr,
                                         q_len, kv_len, ndi);
            });
    }).wait();

    return out;
}

TORCH_LIBRARY(flash_attn_minimal, m) {
    m.def("forward(Tensor Q, Tensor K, Tensor V) -> Tensor");
}
TORCH_LIBRARY_IMPL(flash_attn_minimal, XPU, m) {
    m.impl("forward", &flash_attn_minimal_forward);
}
